# Deployment image settings
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAMESPACE=your-dockerhub-username
BACKEND_IMAGE=your-dockerhub-username/resume-builder-backend
FRONTEND_IMAGE=your-dockerhub-username/resume-builder-frontend
BACKEND_TAG=prod
FRONTEND_TAG=prod

# VPS / GitHub Actions secrets to configure
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-access-token
DEPLOY_HOST=your-vps-ip-or-domain
DEPLOY_USERNAME=your-vps-ssh-user
DEPLOY_SSH_KEY=your-private-ssh-key
DEPLOY_HOST_URL=https://your-domain.example

# Runtime secrets provisioned on the VPS or GitHub environment
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=change-me
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
OPENAI_API_KEY=your-openai-api-key
URLBOX_API_KEY=
