# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1
API_PREFIX=/api

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/resume-builder
MONGODB_TEST_URI=mongodb://localhost:27017/resume-builder-test

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_REFRESH_EXPIRE=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Security
RATE_LIMIT_WINDOW_MS=15
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=10

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@resumebuilder.com

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=resume-builder-uploads

# PDF Generation (uses Chrome/Edge locally — same styled HTML as the editor preview)
# Optional: override browser path if auto-detect fails
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
PDF_FONT_PATH=/fonts
PDF_QUALITY=high
URLBOX_API_KEY=

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# AI Configuration (Optional)
OPENAI_API_KEY=your-openai-api-key
COHERE_API_KEY=your-cohere-api-key

# Admin Configuration
ADMIN_EMAIL=admin@resumebuilder.com
ADMIN_PASSWORD=change-me-in-production

# Analytics
ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90

# Cache Configuration
REDIS_URL=redis://localhost:6379

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,txt

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
